# Environment and Secrets
# Prevents credential leakage into source control
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.cert
*.p12
*.pfx
*.publishsettings
credentials.json
client_secret.json

# Data files — PDFs can exceed GitHub's 100MB limit and bloat history
data/

